# Database — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/agencyflow"

# NextAuth
AUTH_SECRET="your-secret-here-generate-with-openssl-rand-hex-32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary — for file uploads (docs, images, videos)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Optional: seed admin on first run
SEED_ADMIN_EMAIL="admin@youragency.com"
SEED_ADMIN_PASSWORD="changeme"
SEED_ADMIN_NAME="Admin User"
