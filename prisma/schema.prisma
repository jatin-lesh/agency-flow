generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
  CLIENT_USER
}

enum Visibility {
  PRIVATE
  TEAM
  MANAGER_ONLY
  CLIENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum AttachmentType {
  IMAGE
  VIDEO
  DOCUMENT
  OTHER
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String?
  role      Role     @default(MEMBER)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTasks Task[]          @relation("TaskAssignee")
  createdTasks  Task[]          @relation("TaskCreator")
  messages      ThreadMessage[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Client {
  id         String     @id @default(cuid())
  name       String
  industry   String?
  logo       String?
  website    String?
  notes      String?
  visibility Visibility @default(TEAM)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  projects Project[]
  pocs     POC[]
}

model POC {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  jobTitle  String?
  notes     String?
  isPrimary Boolean  @default(false)
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  visibility  Visibility    @default(TEAM)
  dueDate     DateTime?
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  managerId   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tasks Task[]
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  visibility  Visibility @default(TEAM)
  dueDate     DateTime?
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creatorId   String
  creator     User       @relation("TaskCreator", fields: [creatorId], references: [id])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  messages ThreadMessage[]
}

model ThreadMessage {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  isEdited  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments Attachment[]
}

model Attachment {
  id        String         @id @default(cuid())
  name      String
  url       String
  publicId  String?
  type      AttachmentType
  size      Int?
  messageId String
  message   ThreadMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())
}
